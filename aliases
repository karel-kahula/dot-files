alias vim='nvim'
alias vimdiff='nvim -d'
alias vlc='/Applications/VLC.app/Contents/MacOS/VLC'
alias python='python3'
alias pip='pip3'

alias gauth="gcloud auth login && gcloud auth login --update-adc --enable-gdrive-access"
alias garauth="while true; do artifactregistry-auth; sleep 1750; done;"
alias installgarauth="NPM_CONFIG_USERCONFIG=/dev/zero npm install -g google-artifactregistry-auth"
alias gm="gauth && artifactregistry-auth "

alias fss="make firestore-start"
alias fsk="make firestore-kill"

alias bof_mode="puma-dev -uninstall"
alias sc_mode="sudo puma-dev -setup && puma-dev -install -d test"

alias aws-preprod="aws sso login --profile preprod"
alias aws-prod="aws sso login --profile production"

alias po="pomodoro"

alias mysql_local="mysql --host localhost --protocol=tcp -u kkahula"

alias gt="go test ./..."

# force opus: org managed-settings soft-defaults to sonnet 5; --model flag overrides it
alias claude="claude --model opus"
