# Ghostty config — managed in ~/dev/dot-files/ghostty.config
# Symlinked to ~/.config/ghostty/config
# Reload in-app with Cmd+Shift+,
#
# Full option list + docs:
#   /Applications/Ghostty.app/Contents/MacOS/ghostty +show-config --default --docs
# Theme previewer:
#   /Applications/Ghostty.app/Contents/MacOS/ghostty +list-themes

# --- font ---  (JetBrains Mono via `brew install --cask font-jetbrains-mono`)
font-family = "JetBrains Mono"
font-size = 12

# --- theme & color ---
theme = TokyoNight Storm
# background-opacity = 0.95
# background-blur = true

# --- cursor ---
# cursor-style = block
# cursor-style-blink = true

# --- window / chrome ---
window-padding-x = 8
window-padding-y = 8
mouse-hide-while-typing = true
# macos-titlebar-style = transparent
